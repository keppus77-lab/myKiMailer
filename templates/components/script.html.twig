<script>
        let criteria = [];
        let currentSection = null;

        // ==================== LANDING PAGE ====================
        
        function createParticles() {
            const particlesContainer = document.getElementById('particles');
            const particleCount = 50;
            
            for (let i = 0; i < particleCount; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.animationDelay = Math.random() * 15 + 's';
                particle.style.animationDuration = (Math.random() * 10 + 10) + 's';
                particlesContainer.appendChild(particle);
            }
        }

        function openSection(section) {
            currentSection = section;
            
            
             if(section !== 'navi'){
               document.getElementById('landingPage').classList.add('slide-out');
             }
         
            // Deactivate all sections
            document.querySelectorAll('.app-section').forEach(s => s.classList.remove('active'));
            
            // Activate selected section
            if (section === 'search') {
                document.getElementById('searchSection').classList.add('active');
            } else if (section === 'subject') {
                document.getElementById('subjectSection').classList.add('active');
            } else if (section === 'bulk') {
                document.getElementById('bulkSection').classList.add('active');
            } else if (section === 'navi') {
                document.getElementById('naviSection').classList.add('active');
            }
        }

        function goBack() {
            document.getElementById('landingPage').classList.remove('slide-out', 'slide-out-navi');
            document.querySelectorAll('.app-section').forEach(s => s.classList.remove('active'));
            currentSection = null;
        }

        function scrollToTop(sectionId) {
            document.getElementById(sectionId).scrollTo({top: 0, behavior: 'smooth'});
        }

        // ==================== SEARCH BUILDER ====================

        function updateDisplay() {
            const chipsContainer = document.getElementById('criteriaChips');
            const resultElement = document.getElementById('resultCriteria');

            if (criteria.length === 0) {
                chipsContainer.innerHTML = '<div class="empty-state">Keine Kriterien ausgewählt</div>';
                chipsContainer.classList.add('empty');
                resultElement.textContent = 'ALL';
            } else {
                chipsContainer.classList.remove('empty');
                chipsContainer.innerHTML = criteria.map((c, index) => 
                    `<div class="mdc-chip">
                        ${c}
                        <span class="material-icons" onclick="removeCriteria(${index})">close</span>
                    </div>`
                ).join('');
                resultElement.textContent = criteria.join(' ');
            }
        }

        function toggleCriteria(criterion) {
            const index = criteria.indexOf(criterion);
            if (index > -1) {
                criteria.splice(index, 1);
            } else {
                criteria.push(criterion);
            }
            updateDisplay();
        }

        function addTextCriteria(type, inputId) {
            const input = document.getElementById(inputId);
            const value = input.value.trim();
            
            if (!value) {
                alert('Bitte geben Sie einen Wert ein!');
                return;
            }

            const criterion = `${type} "${value}"`;
            criteria.push(criterion);
            input.value = '';
            updateDisplay();
        }

        function removeCriteria(index) {
            const removedCriterion = criteria[index];
            const checkboxId = removedCriterion.toLowerCase().split(' ')[0];
            const checkbox = document.getElementById(checkboxId);
            if (checkbox) {
                checkbox.checked = false;
            }

            criteria.splice(index, 1);
            updateDisplay();
        }

        function clearAll() {
            if (criteria.length === 0) return;
            
            if (confirm('Alle Kriterien löschen?')) {
                document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
                criteria = [];
                updateDisplay();
            }
        }

        function copyToClipboard() {
            const text = criteria.length > 0 ? criteria.join(' ') : 'ALL';
            navigator.clipboard.writeText(text).then(() => {
                const btn = document.getElementById('copyBtn');
                const icon = btn.querySelector('.material-icons');
                const originalText = btn.childNodes[2].textContent;
                
                icon.textContent = 'check';
                btn.childNodes[2].textContent = 'Kopiert!';
                btn.classList.add('copied');
                
                setTimeout(() => {
                    icon.textContent = 'content_copy';
                    btn.childNodes[2].textContent = originalText;
                    btn.classList.remove('copied');
                }, 2000);
            });
        }

        // ==================== SUBJECT CHANGER ====================

        function updateSubjectMode() {
            document.getElementById('prefixMode').style.display = 
                document.getElementById('modePrefix').checked ? 'block' : 'none';
            document.getElementById('replaceMode').style.display = 
                document.getElementById('modeReplace').checked ? 'block' : 'none';
            document.getElementById('customMode').style.display = 
                document.getElementById('modeCustom').checked ? 'block' : 'none';
            updateSubjectCodeOutput();
        }

        function updateSubjectCodeOutput() {
            const host = document.getElementById('imapHost').value || 'imap.gmail.com';
            const port = document.getElementById('imapPort').value || '993';
            const user = document.getElementById('imapUser').value || 'user@example.com';
            const pass = document.getElementById('imapPass').value || 'password';
            const criteria = document.getElementById('subjectSearchCriteria').value || 'ALL';

            document.getElementById('hostOutput').textContent = host;
            document.getElementById('portOutput').textContent = port;
            document.getElementById('userOutput').textContent = user;
            document.getElementById('passOutput').textContent = pass;
            document.getElementById('criteriaOutput').textContent = criteria;
        }

        // Update on input change
        ['imapHost', 'imapPort', 'imapUser', 'imapPass', 'subjectSearchCriteria'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.addEventListener('input', updateSubjectCodeOutput);
        });

        function copySubjectCode() {
            const code = document.getElementById('subjectCodeOutput').textContent;
            navigator.clipboard.writeText(code).then(() => {
                alert('Code kopiert!');
            });
        }

        // ==================== BULK MANAGER ====================

        function updateBulkAction() {
            document.getElementById('moveOptions').style.display = 
                document.getElementById('actionMove').checked ? 'block' : 'none';
            document.getElementById('deleteOptions').style.display = 
                document.getElementById('actionDelete').checked ? 'block' : 'none';
            updateBulkCodeOutput();
        }

        function updateBulkCodeOutput() {
            const host = document.getElementById('bulkImapHost').value || 'imap.gmail.com';
            const port = document.getElementById('bulkImapPort').value || '993';
            const user = document.getElementById('bulkImapUser').value || 'user@example.com';
            const pass = document.getElementById('bulkImapPass').value || 'password';
            const criteria = document.getElementById('bulkSearchCriteria').value || 'ALL';
            const targetFolder = document.getElementById('targetFolder').value || 'INBOX.Archive';

            document.getElementById('bulkHostOutput').textContent = host;
            document.getElementById('bulkPortOutput').textContent = port;
            document.getElementById('bulkUserOutput').textContent = user;
            document.getElementById('bulkPassOutput').textContent = pass;
            document.getElementById('bulkCriteriaOutput').textContent = criteria;
            document.getElementById('targetFolderOutput').textContent = targetFolder;

            let actionCode = '';
            if (document.getElementById('actionMove').checked) {
                actionCode = `<span class="code-function">imap_mail_move</span>(<span class="code-variable">$connection</span>, (string)<span class="code-variable">$emailNum</span>, <span class="code-string">'${targetFolder}'</span>);`;
            } else if (document.getElementById('actionDelete').checked) {
                actionCode = `<span class="code-function">imap_delete</span>(<span class="code-variable">$connection</span>, <span class="code-variable">$emailNum</span>);`;
            } else if (document.getElementById('actionFlag').checked) {
                actionCode = `<span class="code-function">imap_setflag_full</span>(<span class="code-variable">$connection</span>, (string)<span class="code-variable">$emailNum</span>, <span class="code-string">'\\\\Seen'</span>);`;
            } else if (document.getElementById('actionUnflag').checked) {
                actionCode = `<span class="code-function">imap_clearflag_full</span>(<span class="code-variable">$connection</span>, (string)<span class="code-variable">$emailNum</span>, <span class="code-string">'\\\\Seen'</span>);`;
            }

            document.getElementById('bulkActionOutput').innerHTML = actionCode;
        }

        // Update on input change
        ['bulkImapHost', 'bulkImapPort', 'bulkImapUser', 'bulkImapPass', 'bulkSearchCriteria', 'targetFolder'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.addEventListener('input', updateBulkCodeOutput);
        });

        function copyBulkCode() {
            const code = document.getElementById('bulkCodeOutput').textContent;
            navigator.clipboard.writeText(code).then(() => {
                alert('Code kopiert!');
            });
        }

        // ==================== INITIALIZE ====================
        
        createParticles();
        updateDisplay();
        updateSubjectCodeOutput();
        updateBulkCodeOutput();
    </script>
    
    <script>
async function request(url, data, callback) {
  
    // Loader erstellen und anzeigen
    const loader = document.createElement('div');
    loader.className = 'loader';
    document.body.appendChild(loader);

    try {
        // FormData vorbereiten
        const formData = prepareFormData(data);
  
        // CSRF-Token hinzufügen
        addCsrfToken(formData);

        // Fetch-Request
        const response = await fetch(url, {
            method: 'POST',
            body: formData
        });

        // Response-Text holen
        const responseText = await response.text();
        console.log(responseText);

        // Callback ausführen (falls vorhanden)
        if (callback) {
            callback(responseText);
        }

        return responseText;

    } catch (error) {
        console.error('Request failed:', error);
        throw error;

    } finally {
        // Loader immer entfernen (auch bei Fehler)
        loader.remove();
    }
    return false;
}
function prepareFormData(data) {
    if (!data) {
        return new FormData();
    }
    if (data instanceof FormData) {
        return data;
    }
    if (typeof data === 'string') {
        const form = document.querySelector(data);
        return form ? new FormData(form) : new FormData();
    }
    if (typeof data === 'object') {
        const formData = new FormData();
        Object.entries(data).forEach(([key, value]) => {
            formData.append(key, value);
        });
        return formData;
    }
    return new FormData();
}

// Hilfsfunktion: CSRF-Token hinzufÃ¼gen
function addCsrfToken(formData) {
    const csrfMetaTag = document.querySelector('meta[name="csrf_token"]');
    if (csrfMetaTag) {
        formData.append('csrf_token', csrfMetaTag.getAttribute('content'));
    }
}   
function logout() {
    
	request('php/logout.php', '#loginForm', function(data) {
		
        const obj = JSON.parse(data);
        if(obj.code){
   
            switch(obj.code) {
                case '0':
                    window.location = './';
                    break;
                case '1':
                    document.getElementById('errs').innerHTML += '<div class="err">Incorrect username or password</div>';
                    break;
                case '2':
                    document.getElementById('errs').innerHTML += '<div class="err">Failed to connect to database. Please try again later.</div>';
                    break;
                case '3':
                    document.getElementById('errs').innerHTML += '<div class="err">You have exceeded the max number of login attempts per hour. Try again in an hour.</div>';
                    break;
                case '4':
                    document.getElementById('errs').innerHTML += '<div class="err">Your email has not been validated. Please check your email for a validation link or <a href="./validate">click here</a> to send another link</div>';
                    break;
                default:
                    document.getElementById('errs').innerHTML += '<div class="err">An unknown error occurred. Please try again later.</div>';
            }
        }
		setTimeout(function() {
			document.getElementById('errs').style.transition = transition;
			document.getElementById('errs').style.opacity = 1;
		}, 10);
	});
}

