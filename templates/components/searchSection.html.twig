<!-- Query List Modal/Sidebar -->
<div id="queryListContainer" class="query-modal-overlay"></div>
        <script>
        // Globale Variable für aktuelle Query-ID (null = neue Query)
let currentQueryId = null;
let currentCriteria = [];
let criteria = [];

// Query speichern
async function saveQuery() {
    const name = prompt('Name für diese Suche:');
    if (!name) return;
    
    const description = prompt('Beschreibung (optional):');
    
    const data = {
        name: name,
        description: description,
        criteria: JSON.stringify(currentCriteria),
        criteria_string: document.getElementById('resultCriteria').textContent,
        csrf_token: getCsrfToken()
    };
    console.log(data);
    try {
        let url, method;
        
        if (currentQueryId) {
            // Update bestehende Query
            url = `api/imap-search/update/${currentQueryId}`;
            method = 'PUT';
        } else {
            // Neue Query speichern
            url = 'api/imap-search/save';
            method = 'POST';

        }
        
        const response = await fetch(url, {
            method: method,
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
            if (result.id) {
                currentQueryId = result.id;
            }
            showNotification('Erfolgreich gespeichert!', 'success');
            loadQueryList(); // Liste aktualisieren
        } else {
            showNotification('Fehler beim Speichern: ' + result.error, 'error');
        }
        
    } catch (error) {
        console.error('Error:', error);
        showNotification('Netzwerkfehler', 'error');
    }
}

// Query laden
async function loadQuery(id) {
    try {
        const response = await fetch(`api/imap-search/load/${id}`);
        const query = await response.json();
        
        if (query.error) {
            showNotification('Fehler: ' + query.error, 'error');
            return;
        }
        
        // Aktualisiere UI
        currentQueryId = query.id;
        currentCriteria = query.criteria;
        
        // Setze alle Checkboxen und Inputs zurück
        clearAll();

        console.log(query.criteria);
        
        // Lade Kriterien
        query.criteria.forEach(criterion => {
            if (criterion.type === 'checkbox') {
                const checkbox = document.getElementById(criterion.id);
                if (checkbox) {
                    checkbox.checked = true;
                    toggleCriteria(criterion.value);
                }
            } else if (criterion.type === 'text') {
                const input = document.getElementById(criterion.inputId);
                if (input) {
                    input.value = criterion.inputValue;
                    addTextCriteria(criterion.keyword, criterion.inputId);
                }
            }
        });
        
        showNotification('Query geladen: ' + query.name, 'success');
        
    } catch (error) {
        console.error('Error:', error);
        showNotification('Fehler beim Laden', 'error');
    }
}

// Liste aller Queries laden
async function loadQueryList() {
    try {
        const response = await fetch('api/imap-search/list');
        const queries = await response.json();
        
        if (queries.error) {
            console.error('Error loading queries:', queries.error);
            return;
        }
        
        // Zeige Liste in einem Modal/Sidebar
        displayQueryList(queries);
        
    } catch (error) {
        console.error('Error:', error);
    }
}

// Query löschen
async function deleteQuery(id) {
    if (!confirm('Wirklich löschen?')) return;
    
    try {
        const response = await fetch(`api/imap-search/delete/${id}`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                csrf_token: getCsrfToken()
            })
        });
        
        const result = await response.json();
        
        if (result.success) {
            showNotification('Gelöscht!', 'success');
            loadQueryList();
            
            if (currentQueryId === id) {
                clearAll();
                currentQueryId = null;
            }
        }
        
    } catch (error) {
        console.error('Error:', error);
        showNotification('Fehler beim Löschen', 'error');
    }
}

// Angepasste Funktionen (speichere Kriterien in currentCriteria)
function toggleCriteria(keyword) {
    const checkbox = document.getElementById(keyword.toLowerCase());
    alert(checkbox);
    if (checkbox.checked) {
        if (!criteria.includes(keyword)) {
            criteria.push(keyword);
            currentCriteria.push({
                type: 'checkbox',
                id: keyword.toLowerCase(),
                value: keyword
            });
            addChip(keyword, keyword);
        }
    } else {
        criteria = criteria.filter(c => c !== keyword);
        currentCriteria = currentCriteria.filter(c => !(c.type === 'checkbox' && c.value === keyword));
        removeChip(keyword);
    }
    
    updateResult();
}

function addTextCriteria(keyword, inputId) {
    const input = document.getElementById(inputId);
    const value = input.value.trim();
    
    if (value) {
        const criteriaText = `${keyword} "${value}"`;
        criteria.push(criteriaText);
        
        currentCriteria.push({
            type: 'text',
            keyword: keyword,
            inputId: inputId,
            inputValue: value
        });
        
        addChip(criteriaText, inputId + '_' + Date.now());
        updateResult();
        input.value = '';
    }
}

// Chip hinzufügen
function addChip(text, id) {
    const container = document.getElementById('criteriaChips');
    
    // Empty state entfernen
    container.classList.remove('empty');
    const emptyState = container.querySelector('.empty-state');
    if (emptyState) {
        emptyState.remove();
    }
    
    // Chip erstellen
    const chip = document.createElement('div');
    chip.className = 'mdc-chip';
    chip.dataset.criteriaId = id;
    chip.innerHTML = `
        ${text}
        <span class="material-icons" onclick="removeCriteriaById('${id}')">close</span>
    `;
    
    container.appendChild(chip);
}

// Chip entfernen (nach ID)
function removeCriteriaById(id) {
    // Aus DOM entfernen
    const chip = document.querySelector(`[data-criteria-id="${id}"]`);
    if (chip) {
        const text = chip.textContent.replace('close', '').trim();
        chip.remove();
        
        // Aus criteria-Array entfernen
        criteria = criteria.filter(c => c !== text && !c.includes(text));
        
        // Aus currentCriteria entfernen
        currentCriteria = currentCriteria.filter(c => {
            if (c.type === 'checkbox') {
                return c.value !== id && c.id !== id;
            } else if (c.type === 'text') {
                return c.uniqueId !== id;
            }
            return true;
        });
        
        // Checkbox deaktivieren falls vorhanden
        const checkbox = document.getElementById(id);
        if (checkbox) {
            checkbox.checked = false;
        }
        
        // Empty state anzeigen wenn leer
        const container = document.getElementById('criteriaChips');
        if (container.children.length === 0) {
            container.classList.add('empty');
            container.innerHTML = '<div class="empty-state">Keine Kriterien ausgewählt</div>';
        }
        
        updateResult();
    }
}

// Alte removeChip-Funktion (für Checkbox-Kompatibilität)
function removeChip(keyword) {
    removeCriteriaById(keyword);
}

// Alle Kriterien löschen
function clearAll() {
    criteria = [];
    currentCriteria = [];
    currentQueryId = null;
    
    // Alle Checkboxen deaktivieren
    document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
    
    // Alle Inputs leeren
    document.querySelectorAll('.mdc-text-field input').forEach(input => input.value = '');
    
    // Chips-Container zurücksetzen
    const container = document.getElementById('criteriaChips');
    container.classList.add('empty');
    container.innerHTML = '<div class="empty-state">Keine Kriterien ausgewählt</div>';
    
    updateResult();
}

// Ergebnis aktualisieren
function updateResult() {
    const resultElement = document.getElementById('resultCriteria');
    
    if (criteria.length === 0) {
        resultElement.textContent = 'ALL';
    } else {
        resultElement.textContent = criteria.join(' ');
    }
}

// CSRF-Token holen
function getCsrfToken() {
    return document.querySelector('meta[name="csrf_token"]').content;
}

// Notification anzeigen
function showNotification(message, type) {
    // Nutze dein eigenes Notification-System
    alert(message);
}

// Query-Liste anzeigen (Beispiel)
function displayQueryList_(queries) {
    alert("werwer");
    const html = queries.map(q => `
        <div class="query-item">
            <h3>${q.name}</h3>
            <p>${q.description || ''}</p>
            <code>${q.criteria_string}</code>
            <button onclick="loadQuery(${q.id})">Laden</button>
            <button onclick="deleteQuery(${q.id})">Löschen</button>
        </div>
    `).join('');
    
    // Zeige in einem Modal/Sidebar
    document.getElementById('queryListContainer').innerHTML = html;
    document.getElementById('queryListContainer').style.display = "block";
}


function displayQueryList(queries) {
    const container = document.getElementById('queryListContainer');
    
    // Wenn keine Queries vorhanden
    if (queries.length === 0) {
        container.innerHTML = `
            <div class="query-modal">
                <div class="query-modal-header">
                    <div class="query-modal-title">
                        <span class="material-icons">folder_open</span>
                        <h2>Gespeicherte Suchen</h2>
                    </div>
                    <button class="icon-btn close-modal" onclick="closeQueryList()">
                        <span class="material-icons">close</span>
                    </button>
                </div>
                
                <div class="query-modal-body">
                    <div class="query-empty-state">
                        <span class="material-icons">search_off</span>
                        <h3>Keine gespeicherten Suchen</h3>
                        <p>Erstelle deine erste Suche und speichere sie für später.</p>
                    </div>
                </div>
                
                <div class="query-modal-footer">
                    <button class="mdc-button mdc-button--outlined" onclick="closeQueryList()">
                        <span class="material-icons">close</span>
                        Schließen
                    </button>
                </div>
            </div>
        `;
    } else {
        // Mit Queries
        const queryItems = queries.map(q => {
            const createdDate = new Date(q.created_at);
            const timeAgo = getTimeAgo(createdDate);
            
            return `
                <div class="query-item">
                    <div class="query-item-icon">
                        <span class="material-icons">search</span>
                    </div>
                    <div class="query-item-content">
                        <div class="query-item-header">
                            <h3>${escapeHtml(q.name)}</h3>
                            <div class="query-item-meta">
                                <small>${timeAgo}</small>
                            </div>
                        </div>
                        ${q.description ? `<p class="query-item-description">${escapeHtml(q.description)}</p>` : ''}
                        <div class="query-item-criteria">
                            <code>${escapeHtml(q.criteria_string)}</code>
                        </div>
                    </div>
                    <div class="query-item-actions">
                        <button class="icon-btn" onclick="loadQuery(${q.id}); closeQueryList();" title="Laden">
                            <span class="material-icons">open_in_new</span>
                        </button>
                        <button class="icon-btn icon-btn--danger" onclick="deleteQuery(${q.id})" title="Löschen">
                            <span class="material-icons">delete</span>
                        </button>
                    </div>
                </div>
            `;
        }).join('');
        
        container.innerHTML = `
            <div class="query-modal">
                <div class="query-modal-header">
                    <div class="query-modal-title">
                        <span class="material-icons">folder_open</span>
                        <h2>Gespeicherte Suchen</h2>
                    </div>
                    <button class="icon-btn close-modal" onclick="closeQueryList()">
                        <span class="material-icons">close</span>
                    </button>
                </div>
                
                <div class="query-modal-body">
                    <div class="query-list">
                        ${queryItems}
                    </div>
                </div>
                
                <div class="query-modal-footer">
                    <button class="mdc-button mdc-button--outlined" onclick="closeQueryList()">
                        <span class="material-icons">close</span>
                        Schließen
                    </button>
                </div>
            </div>
        `;
    }
    
    // Modal anzeigen
    container.classList.add('active');
    
    // Klick außerhalb schließt Modal
    setTimeout(() => {
        container.addEventListener('click', function(e) {
            if (e.target === container) {
                closeQueryList();
            }
        });
    }, 100);
}
// Modal schließen
function closeQueryList() {
    const container = document.getElementById('queryListContainer');
    container.classList.remove('active');
    setTimeout(() => {
        container.innerHTML = '';
    }, 300);
}

// Zeit seit Erstellung berechnen
function getTimeAgo(date) {
    const now = new Date();
    const seconds = Math.floor((now - date) / 1000);
    
    const intervals = {
        'Jahr': 31536000,
        'Monat': 2592000,
        'Woche': 604800,
        'Tag': 86400,
        'Stunde': 3600,
        'Minute': 60
    };
    
    for (const [name, secondsInterval] of Object.entries(intervals)) {
        const interval = Math.floor(seconds / secondsInterval);
        if (interval >= 1) {
            return `vor ${interval} ${name}${interval !== 1 ? (name === 'Monat' ? 'en' : name === 'Jahr' ? 'en' : 'n') : ''}`;
        }
    }
    
    return 'gerade eben';
}

// XSS-Schutz
function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

        </script>