<div class="app-bar">
            <div class="app-bar-content">
                <div class="app-bar-left">
                    <button class="back-button" onclick="goBack()" title="Zurück">
                        <span class="material-icons">arrow_back</span>
                    </button>
                    <div>
                        <h1>
                            <span class="material-icons">search</span>
                            IMAP Search Criteria Builder
                        </h1>
                        <p>Erstelle komplexe IMAP-Suchkriterien für PHP imap_search()</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="container">
            <div class="info-banner">
                <span class="material-icons">info</span>
                <div class="info-banner-text">
                    Füge Kriterien hinzu, um deine Suchanfrage zu erstellen. Alle Kriterien werden mit AND verknüpft.
                </div>
            </div>

            <div class="mdc-card">
                <div class="card-header">
                    <span class="material-icons">label</span>
                    <h2>Aktuelle Suchkriterien</h2>
                </div>
                <div class="card-content">
                    <div class="criteria-chips-container empty" id="criteriaChips">
                        <div class="empty-state">Keine Kriterien ausgewählt</div>
                    </div>
                    <button class="mdc-button mdc-button--outlined" onclick="clearAll()">
                        <span class="material-icons">delete_outline</span>
                        Alle löschen
                    </button>
                </div>
            </div>

            <div class="mdc-card">
                <div class="card-header">
                    <span class="material-icons">tune</span>
                    <h2>Basis-Kriterien</h2>
                </div>
                <div class="card-content">
                    <div class="checkbox-grid">
                        <div class="mdc-form-field">
                            <div class="mdc-checkbox">
                                <input type="checkbox" id="all" onchange="toggleCriteria('ALL')">
                            </div>
                            <label for="all">ALL - Alle Nachrichten</label>
                        </div>
                        <div class="mdc-form-field">
                            <div class="mdc-checkbox">
                                <input type="checkbox" id="unseen" onchange="toggleCriteria('UNSEEN')">
                            </div>
                            <label for="unseen">UNSEEN - Ungelesen</label>
                        </div>
                        <div class="mdc-form-field">
                            <div class="mdc-checkbox">
                                <input type="checkbox" id="seen" onchange="toggleCriteria('SEEN')">
                            </div>
                            <label for="seen">SEEN - Gelesen</label>
                        </div>
                        <div class="mdc-form-field">
                            <div class="mdc-checkbox">
                                <input type="checkbox" id="flagged" onchange="toggleCriteria('FLAGGED')">
                            </div>
                            <label for="flagged">FLAGGED - Markiert</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mdc-card">
                <div class="card-header">
                    <span class="material-icons">text_fields</span>
                    <h2>Text-Suche</h2>
                </div>
                <div class="card-content">
                    <div class="input-grid">
                        <div>
                            <div class="mdc-text-field">
                                <label>FROM - Von</label>
                                <input type="text" id="from" placeholder='z.B. "user@example.com"'>
                            </div>
                            <button class="mdc-button mdc-button--raised mdc-button--fullwidth" onclick="addTextCriteria('FROM', 'from')">
                                <span class="material-icons">add</span>
                                Hinzufügen
                            </button>
                        </div>
                        <div>
                            <div class="mdc-text-field">
                                <label>SUBJECT - Betreff</label>
                                <input type="text" id="subject" placeholder='z.B. "Rechnung"'>
                            </div>
                            <button class="mdc-button mdc-button--raised mdc-button--fullwidth" onclick="addTextCriteria('SUBJECT', 'subject')">
                                <span class="material-icons">add</span>
                                Hinzufügen
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mdc-card">
                <div class="card-header">
                    <span class="material-icons">code</span>
                    <h2>Generierter PHP-Code</h2>
                </div>
                <div class="card-content">
                    <div class="code-block">
                        <button class="copy-button" id="copyBtn" onclick="copyToClipboard()">
                            <span class="material-icons">content_copy</span>
                            Kopieren
                        </button>
                        <code><span class="code-variable">$criteria</span> = <span class="code-string">'<span id="resultCriteria">ALL</span>'</span>;</code><br>
                        <code><span class="code-variable">$emails</span> = <span class="code-function">imap_search</span>(<span class="code-variable">$connection</span>, <span class="code-variable">$criteria</span>);</code>
                    </div>
                </div>
            </div>
        </div>

        <div class="fab-container">
            <button class="mdc-fab" onclick="scrollToTop('searchSection')" title="Nach oben">
                <span class="material-icons">arrow_upward</span>
            </button>
        </div>

        <!-- Speichern/Laden Buttons -->
<div class="mdc-card">
    <div class="card-header">
        <span class="material-icons">save</span>
        <h2>Query verwalten</h2>
    </div>
    <div class="card-content">
        <button class="mdc-button mdc-button--raised" onclick="saveQuery()">
            <span class="material-icons">save</span>
            Speichern
        </button>
        <button class="mdc-button mdc-button--outlined" onclick="loadQueryList()">
            <span class="material-icons">folder_open</span>
            Laden
        </button>
        <button class="mdc-button mdc-button--outlined" onclick="newQuery()">
            <span class="material-icons">add</span>
            Neue Query
        </button>
    </div>
</div>



<!-- Query List Modal/Sidebar -->
<div id="queryListContainer" style="display:none;"></div>


        <script>
        // Globale Variable für aktuelle Query-ID (null = neue Query)
let currentQueryId = null;
let currentCriteria = [];

// Query speichern
async function saveQuery() {
    const name = prompt('Name für diese Suche:');
    if (!name) return;
    
    const description = prompt('Beschreibung (optional):');
    
    const data = {
        name: name,
        description: description,
        criteria: currentCriteria,
        criteria_string: document.getElementById('resultCriteria').textContent,
        csrf_token: getCsrfToken()
    };
    console.log(data);
    try {
        let url, method;
        
        if (currentQueryId) {
            // Update bestehende Query
            url = `api/imap-search/update/${currentQueryId}`;
            method = 'PUT';
        } else {
            // Neue Query speichern
            url = 'api/imap-search/save';
            method = 'POST';
        }
        
        const response = await fetch(url, {
            method: method,
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(data)
        });
        
        const result = await response.json();
        
        if (result.success) {
            if (result.id) {
                currentQueryId = result.id;
            }
            showNotification('Erfolgreich gespeichert!', 'success');
            loadQueryList(); // Liste aktualisieren
        } else {
            showNotification('Fehler beim Speichern: ' + result.error, 'error');
        }
        
    } catch (error) {
        console.error('Error:', error);
        showNotification('Netzwerkfehler', 'error');
    }
}

// Query laden
async function loadQuery(id) {
    try {
        const response = await fetch(`api/imap-search/load/${id}`);
        const query = await response.json();
        
        if (query.error) {
            showNotification('Fehler: ' + query.error, 'error');
            return;
        }
        
        // Aktualisiere UI
        currentQueryId = query.id;
        currentCriteria = query.criteria;
        
        // Setze alle Checkboxen und Inputs zurück
        clearAll();
        
        // Lade Kriterien
        query.criteria.forEach(criterion => {
            if (criterion.type === 'checkbox') {
                const checkbox = document.getElementById(criterion.id);
                if (checkbox) {
                    checkbox.checked = true;
                    toggleCriteria(criterion.value);
                }
            } else if (criterion.type === 'text') {
                const input = document.getElementById(criterion.inputId);
                if (input) {
                    input.value = criterion.inputValue;
                    addTextCriteria(criterion.keyword, criterion.inputId);
                }
            }
        });
        
        showNotification('Query geladen: ' + query.name, 'success');
        
    } catch (error) {
        console.error('Error:', error);
        showNotification('Fehler beim Laden', 'error');
    }
}

// Liste aller Queries laden
async function loadQueryList() {
    try {
        const response = await fetch('api/imap-search/list');
        const queries = await response.json();
        
        if (queries.error) {
            console.error('Error loading queries:', queries.error);
            return;
        }
        
        // Zeige Liste in einem Modal/Sidebar
        displayQueryList(queries);
        
    } catch (error) {
        console.error('Error:', error);
    }
}

// Query löschen
async function deleteQuery(id) {
    if (!confirm('Wirklich löschen?')) return;
    
    try {
        const response = await fetch(`api/imap-search/delete/${id}`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                csrf_token: getCsrfToken()
            })
        });
        
        const result = await response.json();
        
        if (result.success) {
            showNotification('Gelöscht!', 'success');
            loadQueryList();
            
            if (currentQueryId === id) {
                clearAll();
                currentQueryId = null;
            }
        }
        
    } catch (error) {
        console.error('Error:', error);
        showNotification('Fehler beim Löschen', 'error');
    }
}

// Angepasste Funktionen (speichere Kriterien in currentCriteria)
function toggleCriteria(keyword) {
    const checkbox = document.getElementById(keyword.toLowerCase());
    
    if (checkbox.checked) {
        if (!criteria.includes(keyword)) {
            criteria.push(keyword);
            currentCriteria.push({
                type: 'checkbox',
                id: keyword.toLowerCase(),
                value: keyword
            });
            addChip(keyword, keyword);
        }
    } else {
        criteria = criteria.filter(c => c !== keyword);
        currentCriteria = currentCriteria.filter(c => !(c.type === 'checkbox' && c.value === keyword));
        removeChip(keyword);
    }
    
    updateResult();
}

function addTextCriteria(keyword, inputId) {
    const input = document.getElementById(inputId);
    const value = input.value.trim();
    
    if (value) {
        const criteriaText = `${keyword} "${value}"`;
        criteria.push(criteriaText);
        
        currentCriteria.push({
            type: 'text',
            keyword: keyword,
            inputId: inputId,
            inputValue: value
        });
        
        addChip(criteriaText, inputId + '_' + Date.now());
        updateResult();
        input.value = '';
    }
}

// CSRF-Token holen
function getCsrfToken() {
    return document.querySelector('meta[name="csrf_token"]').content;
}

// Notification anzeigen
function showNotification(message, type) {
    // Nutze dein eigenes Notification-System
    alert(message);
}

// Query-Liste anzeigen (Beispiel)
function displayQueryList(queries) {
    const html = queries.map(q => `
        <div class="query-item">
            <h3>${q.name}</h3>
            <p>${q.description || ''}</p>
            <code>${q.criteria_string}</code>
            <button onclick="loadQuery(${q.id})">Laden</button>
            <button onclick="deleteQuery(${q.id})">Löschen</button>
        </div>
    `).join('');
    
    // Zeige in einem Modal/Sidebar
    document.getElementById('queryListContainer').innerHTML = html;
}

        </script>