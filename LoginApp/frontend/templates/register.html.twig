
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    
	<meta name="csrf_token" content="{{csrf_token}}" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrierung - Password Strength</title>
   {% include 'components/authcss.html.twig' %}
</head>
<body>
    <div class="container">
        <h1>🚀 Registrierung</h1>
        <p class="subtitle">Erstelle dein kostenloses Konto</p>

        <form id="registrationForm" novalidate>
            <!-- Name Field -->
            <div class="form-group">
                <label for="name">
                    Vollständiger Name <span class="required">*</span>
                </label>
                <div class="input-wrapper">
                    <input 
                        type="text" 
                        id="name" 
                        name="name"
                        placeholder="Max Mustermann"
                        required
                    >
                </div>
                <div class="message" id="nameMessage"></div>
            </div>

            <!-- Email Field -->
            <div class="form-group">
                <label for="email">
                    E-Mail-Adresse <span class="required">*</span>
                </label>
                <div class="input-wrapper">
                    <input 
                        type="email" 
                        id="email" 
                        name="email"
                        placeholder="max@example.com"
                        required
                    >
                </div>
                <div class="message" id="emailMessage"></div>
            </div>

            <!-- Password Field -->
            <div class="form-group">
                <label for="password">
                    Passwort <span class="required">*</span>
                </label>
                <div class="input-wrapper">
                    <input 
                        type="password" 
                        id="password" 
                        name="password"
                        placeholder="Mindestens 8 Zeichen"
                        required
                    >
                    <button class="toggle-password" type="button" id="togglePassword">
                        👁️
                    </button>
                </div>
                <div class="strength-bar-container" id="strengthBarContainer">
                    <div class="strength-bar" id="strengthBar"></div>
                </div>
                <div class="message" id="passwordMessage"></div>

                <!-- Password Requirements -->
                <div class="requirements" id="requirements">
                    <h4>Passwort-Anforderungen:</h4>
                    <div class="requirement" id="reqLength">
                        <span class="requirement-icon">✗</span>
                        <span>Mindestens 8 Zeichen</span>
                    </div>
                    <div class="requirement" id="reqLowercase">
                        <span class="requirement-icon">✗</span>
                        <span>Kleinbuchstaben (a-z)</span>
                    </div>
                    <div class="requirement" id="reqUppercase">
                        <span class="requirement-icon">✗</span>
                        <span>Großbuchstaben (A-Z)</span>
                    </div>
                    <div class="requirement" id="reqNumber">
                        <span class="requirement-icon">✗</span>
                        <span>Zahlen (0-9)</span>
                    </div>
                    <div class="requirement" id="reqSpecial">
                        <span class="requirement-icon">✗</span>
                        <span>Sonderzeichen (!@#$%^&*)</span>
                    </div>
                </div>
            </div>

	
            <!-- Password Confirmation Field -->
            <div class="form-group">
                <label for="passwordConfirm">
                    Passwort wiederholen <span class="required">*</span>
                </label>
                <div class="input-wrapper">
                    <input 
                        type="password" 
                        id="passwordConfirm" 
                        name="confirm-password"
                        placeholder="Passwort erneut eingeben"
                        required
                    >
                    <button class="toggle-password" type="button" id="togglePasswordConfirm">
                        👁️
                    </button>
                </div>
                <div class="message" id="passwordConfirmMessage"></div>
            </div>

            <!-- Submit Button -->
            <button onclick="register();return false;" class="submit-btn" id="submitBtn" disabled>
                Jetzt registrieren
            </button>
        </form>

        <!-- Login Link -->
        <div class="login-link">
            Du hast bereits ein Konto? <a href="#login">Jetzt anmelden</a>
        </div>
    </div>

    <!-- Success Modal -->
    <div class="modal" id="successModal">
        <div class="modal-content">
            <div class="modal-icon">🎉</div>
            <h2>Erfolgreich registriert!</h2>
            <p>Dein Konto wurde erfolgreich erstellt. Du kannst dich jetzt anmelden.</p>
            <button class="modal-btn" onclick="closeModal()">Verstanden</button>
        </div>
    </div>



    <script>
        // Form Elements
        const form = document.getElementById('registrationForm');
        const nameInput = document.getElementById('name');
        const emailInput = document.getElementById('email');
        const passwordInput = document.getElementById('password');
        const passwordConfirmInput = document.getElementById('passwordConfirm');
        const submitBtn = document.getElementById('submitBtn');

        // Message Elements
        const nameMessage = document.getElementById('nameMessage');
        const emailMessage = document.getElementById('emailMessage');
        const passwordMessage = document.getElementById('passwordMessage');
        const passwordConfirmMessage = document.getElementById('passwordConfirmMessage');

        // Password Strength Elements
        const strengthBar = document.getElementById('strengthBar');
        const strengthBarContainer = document.getElementById('strengthBarContainer');
        const requirementsEl = document.getElementById('requirements');
        const requirements = {
            length: document.getElementById('reqLength'),
            lowercase: document.getElementById('reqLowercase'),
            uppercase: document.getElementById('reqUppercase'),
            number: document.getElementById('reqNumber'),
            special: document.getElementById('reqSpecial')
        };

        // Toggle Password Visibility
        const togglePassword = document.getElementById('togglePassword');
        const togglePasswordConfirm = document.getElementById('togglePasswordConfirm');

        togglePassword.addEventListener('click', function() {
            togglePasswordVisibility(passwordInput, this);
        });

        togglePasswordConfirm.addEventListener('click', function() {
            togglePasswordVisibility(passwordConfirmInput, this);
        });

        function togglePasswordVisibility(input, button) {
            const type = input.type === 'password' ? 'text' : 'password';
            input.type = type;
            button.textContent = type === 'password' ? '👁️' : '🙈';
        }

        // Validation State
        const validationState = {
            name: false,
            email: false,
            password: false,
            passwordConfirm: false
        };

        // Name Validation
        nameInput.addEventListener('input', function() {
            const value = this.value.trim();
            
            if (value.length === 0) {
                showMessage(nameMessage, '', '');
                this.classList.remove('valid', 'invalid');
                validationState.name = false;
            } else if (value.length < 2) {
                showMessage(nameMessage, 'Name muss mindestens 2 Zeichen lang sein', 'error');
                this.classList.remove('valid');
                this.classList.add('invalid');
                validationState.name = false;
            } else if (!/^[a-zA-ZäöüÄÖÜß\s-]+$/.test(value)) {
                showMessage(nameMessage, 'Nur Buchstaben, Leerzeichen und Bindestriche erlaubt', 'error');
                this.classList.remove('valid');
                this.classList.add('invalid');
                validationState.name = false;
            } else {
                showMessage(nameMessage, '✓ Name ist gültig', 'success');
                this.classList.remove('invalid');
                this.classList.add('valid');
                validationState.name = true;
            }
            
            updateSubmitButton();
        });

        // Email Validation
        emailInput.addEventListener('input', function() {
            const value = this.value.trim();
            
            if (value.length === 0) {
                showMessage(emailMessage, '', '');
                this.classList.remove('valid', 'invalid');
                validationState.email = false;
            } else if (!isValidEmail(value)) {
                showMessage(emailMessage, 'Bitte gib eine gültige E-Mail-Adresse ein', 'error');
                this.classList.remove('valid');
                this.classList.add('invalid');
                validationState.email = false;
            } else {
                showMessage(emailMessage, '✓ E-Mail ist gültig', 'success');
                this.classList.remove('invalid');
                this.classList.add('valid');
                validationState.email = true;
            }
            
            updateSubmitButton();
        });

        function isValidEmail(email) {
            const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            return re.test(email);
        }

        // Password Validation
        passwordInput.addEventListener('focus', function() {
            strengthBarContainer.classList.add('show');
            requirementsEl.classList.add('show');
        });

        passwordInput.addEventListener('input', function() {
            const password = this.value;
            const result = checkPasswordStrength(password);
            
            updatePasswordUI(result);
            
            // Check if password confirmation matches
            if (passwordConfirmInput.value.length > 0) {
                validatePasswordConfirm();
            }
            
            updateSubmitButton();
        });

        function checkPasswordStrength(password) {
            let score = 0;
            const checks = {
                length: false,
                lowercase: false,
                uppercase: false,
                number: false,
                special: false
            };

            // Length check
            if (password.length >= 8) {
                checks.length = true;
                score += 20;
            }
            if (password.length >= 12) score += 10;
            if (password.length >= 16) score += 10;

            // Lowercase letters
            if (/[a-z]/.test(password)) {
                checks.lowercase = true;
                score += 10;
            }

            // Uppercase letters
            if (/[A-Z]/.test(password)) {
                checks.uppercase = true;
                score += 10;
            }

            // Numbers
            if (/[0-9]/.test(password)) {
                checks.number = true;
                score += 10;
            }

            // Special characters
            if (/[!@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(password)) {
                checks.special = true;
                score += 15;
            }

            // Variety bonus
            const uniqueChars = new Set(password).size;
            if (uniqueChars >= 8) score += 10;
            if (uniqueChars >= 12) score += 5;

            // No repeated characters bonus
            if (!/(.)\1{2,}/.test(password)) score += 5;

            // Penalties
            if (/abc|bcd|cde|123|234|345|qwerty|password/i.test(password)) {
                score -= 15;
            }

            score = Math.max(0, Math.min(100, score));

            // Determine strength
            let strength = 'weak';
            if (score >= 80) strength = 'strong';
            else if (score >= 60) strength = 'good';
            else if (score >= 40) strength = 'fair';

            // Check if all requirements are met
            const allRequirementsMet = Object.values(checks).every(check => check === true);

            return {
                score: score,
                strength: strength,
                checks: checks,
                isValid: allRequirementsMet && score >= 60
            };
        }

        function updatePasswordUI(result) {
            // Update strength bar
            strengthBar.className = 'strength-bar ' + result.strength;

            // Update requirements
            updateRequirement(requirements.length, result.checks.length);
            updateRequirement(requirements.lowercase, result.checks.lowercase);
            updateRequirement(requirements.uppercase, result.checks.uppercase);
            updateRequirement(requirements.number, result.checks.number);
            updateRequirement(requirements.special, result.checks.special);

            // Update message
            if (passwordInput.value.length === 0) {
                showMessage(passwordMessage, '', '');
                passwordInput.classList.remove('valid', 'invalid');
                validationState.password = false;
            } else if (result.isValid) {
                const strengthLabels = {
                    fair: 'Mittel - Akzeptabel',
                    good: 'Gut - Empfohlen',
                    strong: 'Stark - Sehr sicher!'
                };
                showMessage(passwordMessage, `✓ ${strengthLabels[result.strength]}`, 'success');
                passwordInput.classList.remove('invalid');
                passwordInput.classList.add('valid');
                validationState.password = true;
            } else {
                showMessage(passwordMessage, 'Passwort erfüllt nicht alle Anforderungen', 'error');
                passwordInput.classList.remove('valid');
                passwordInput.classList.add('invalid');
                validationState.password = false;
            }
        }

        function updateRequirement(element, isMet) {
            const icon = element.querySelector('.requirement-icon');
            
            if (isMet) {
                element.classList.add('met');
                icon.textContent = '✓';
            } else {
                element.classList.remove('met');
                icon.textContent = '✗';
            }
        }

        // Password Confirmation Validation
        passwordConfirmInput.addEventListener('input', validatePasswordConfirm);

        function validatePasswordConfirm() {
            const password = passwordInput.value;
            const passwordConfirm = passwordConfirmInput.value;
            
            if (passwordConfirm.length === 0) {
                showMessage(passwordConfirmMessage, '', '');
                passwordConfirmInput.classList.remove('valid', 'invalid');
                validationState.passwordConfirm = false;
            } else if (password !== passwordConfirm) {
                showMessage(passwordConfirmMessage, 'Passwörter stimmen nicht überein', 'error');
                passwordConfirmInput.classList.remove('valid');
                passwordConfirmInput.classList.add('invalid');
                validationState.passwordConfirm = false;
            } else {
                showMessage(passwordConfirmMessage, '✓ Passwörter stimmen überein', 'success');
                passwordConfirmInput.classList.remove('invalid');
                passwordConfirmInput.classList.add('valid');
                validationState.passwordConfirm = true;
            }
            
            updateSubmitButton();
        }

        // Show Message Helper
        function showMessage(element, text, type) {
            element.textContent = text;
            element.className = 'message';
            
            if (text) {
                element.classList.add('show', type);
            }
        }

        // Update Submit Button
        function updateSubmitButton() {
            const allValid = Object.values(validationState).every(v => v === true);
            submitBtn.disabled = !allValid;
        }

        

        async function request(url, data, callback) {
  
    // Loader erstellen und anzeigen
    const loader = document.createElement('div');
    loader.className = 'loader';
    document.body.appendChild(loader);

    try {
        // FormData vorbereiten
        const formData = prepareFormData(data);
  
        // CSRF-Token hinzufügen
        addCsrfToken(formData);

        // Fetch-Request
        const response = await fetch(url, {
            method: 'POST',
            body: formData
        });

        // Response-Text holen
        const responseText = await response.text();
        console.log(responseText);

        // Callback ausführen (falls vorhanden)
        if (callback) {
            callback(responseText);
        }

        return responseText;

    } catch (error) {
        console.error('Request failed:', error);
        throw error;

    } finally {
        // Loader immer entfernen (auch bei Fehler)
        loader.remove();
    }
    return false;
}
function prepareFormData(data) {
    if (!data) {
        return new FormData();
    }
    if (data instanceof FormData) {
        return data;
    }
    if (typeof data === 'string') {
        const form = document.querySelector(data);
        return form ? new FormData(form) : new FormData();
    }
    if (typeof data === 'object') {
        const formData = new FormData();
        Object.entries(data).forEach(([key, value]) => {
            formData.append(key, value);
        });
        return formData;
    }
    return new FormData();
}

// Hilfsfunktion: CSRF-Token hinzufÃ¼gen
function addCsrfToken(formData) {
    const csrfMetaTag = document.querySelector('meta[name="csrf_token"]');
    if (csrfMetaTag) {
        formData.append('csrf_token', csrfMetaTag.getAttribute('content'));
    }
}   
function register() {
    
	request('{{request_url}}/register', '#registrationForm', function(data) {
		
        const obj = JSON.parse(data);
        if(obj.code){
   
            switch(obj.code) {
                case '0':
                    showSuccessModal();
                    break;
               
                default:
                    document.getElementById('errs').innerHTML += '<div class="err">An unknown error occurred. Please try again later.</div>';
            }
        }
		setTimeout(function() {
			document.getElementById('errs').style.transition = transition;
			document.getElementById('errs').style.opacity = 1;
		}, 10);
	});
}

        // Success Modal
        function showSuccessModal() {
            document.getElementById('successModal').classList.add('show');
        }

        function closeModal() {
            document.getElementById('successModal').classList.remove('show');
            form.reset();
            
            // Reset validation states
            Object.keys(validationState).forEach(key => validationState[key] = false);
            
            // Clear all messages and classes
            document.querySelectorAll('.message').forEach(msg => {
                msg.className = 'message';
                msg.textContent = '';
            });
            
            document.querySelectorAll('input').forEach(input => {
                input.classList.remove('valid', 'invalid');
            });
            
            // Hide password strength elements
            strengthBarContainer.classList.remove('show');
            requirementsEl.classList.remove('show');
            strengthBar.className = 'strength-bar';
            
            updateSubmitButton();
        }
    </script>
</body>
</html>
