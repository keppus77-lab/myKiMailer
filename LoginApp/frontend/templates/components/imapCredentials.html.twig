    <script>
    // =============================================================
// IMAP Accounts Management - JavaScript
// =============================================================

// Globale Variablen
let currentAccountId = null;
const userId = 1; // TODO: Von Session/Auth holen

// Provider-Konfigurationen
const PROVIDERS = {
    gmail: {
        name: 'Gmail',
        host: 'imap.gmail.com',
        port: 993,
        useSsl: true,
        helpText: 'Nutze ein App-Passwort: https://myaccount.google.com/apppasswords'
    },
    outlook: {
        name: 'Outlook / Office 365',
        host: 'outlook.office365.com',
        port: 993,
        useSsl: true,
        helpText: 'Funktioniert auch für Hotmail und Live.com'
    },
    yahoo: {
        name: 'Yahoo Mail',
        host: 'imap.mail.yahoo.com',
        port: 993,
        useSsl: true,
        helpText: 'App-Passwort erforderlich bei aktivierter 2FA'
    },
    gmx: {
        name: 'GMX',
        host: 'imap.gmx.net',
        port: 993,
        useSsl: true
    },
    webde: {
        name: 'Web.de',
        host: 'imap.web.de',
        port: 993,
        useSsl: true
    },
    icloud: {
        name: 'iCloud',
        host: 'imap.mail.me.com',
        port: 993,
        useSsl: true,
        helpText: 'App-spezifisches Passwort erforderlich'
    },
    custom: {
        name: 'Eigener Server',
        host: '',
        port: 993,
        useSsl: true
    }
};

// =============================================================
// Initialisierung
// =============================================================

document.addEventListener('DOMContentLoaded', function() {
    loadAccountsList();
});

// =============================================================
// Provider-Auswahl
// =============================================================

function selectProvider(providerKey) {
    const provider = PROVIDERS[providerKey];
    
    if (!provider) return;
    
    // Alle Provider-Buttons deaktivieren
    document.querySelectorAll('.provider-button').forEach(btn => {
        btn.classList.remove('active');
    });
    
    // Gewählten Provider aktivieren
    event.target.closest('.provider-button').classList.add('active');
    
    // Felder ausfüllen (außer bei custom)
    if (providerKey !== 'custom') {
        document.getElementById('host').value = provider.host;
        document.getElementById('port').value = provider.port;
        document.getElementById('useSsl').checked = provider.useSsl;
        
        // Felder readonly machen
        document.getElementById('host').readOnly = true;
        document.getElementById('port').readOnly = true;
    } else {
        // Bei custom: Felder editierbar
        document.getElementById('host').value = '';
        document.getElementById('port').value = 993;
        document.getElementById('host').readOnly = false;
        document.getElementById('port').readOnly = false;
    }
    
    // Hilfetext anzeigen
    if (provider.helpText) {
        showImapNotification(provider.helpText, 'info');
    }
}

// =============================================================
// Formular anzeigen/verstecken
// =============================================================

function showAddAccountForm() {
    document.getElementById('accountFormCard').style.display = 'block';
    document.getElementById('formTitle').innerHTML = `
     
        Neuen IMAP-Account hinzufügen
    `;
    document.getElementById('accountForm').reset();
    document.getElementById('accountId').value = '';
    currentAccountId = null;
    
    // Scroll zu Formular
    document.getElementById('accountFormCard').scrollIntoView({ behavior: 'smooth' });
}

function showEditAccountForm(accountId) {
    // Account-Daten laden
    fetch(`api/imap-accounts/get/${accountId}`)
        .then(response => response.json())
        .then(account => {
            if (account.error) {
                showImapNotification('Fehler: ' + account.error, 'error');
                return;
            }
            
            // Formular anzeigen
            document.getElementById('accountFormCard').style.display = 'block';
            document.getElementById('formTitle').innerHTML = `
                <span class="material-icons">edit</span>
                Account bearbeiten
            `;
            
            // Felder füllen
            document.getElementById('accountId').value = account.id;
            document.getElementById('email').value = account.email;
            document.getElementById('username').value = account.imap_username || '';
            document.getElementById('password').value = ''; // Passwort nicht anzeigen
            document.getElementById('host').value = account.imap_host;
            document.getElementById('port').value = account.imap_port;
            document.getElementById('useSsl').checked = account.use_ssl;
            
            currentAccountId = accountId;
            
            // Provider auto-detect
            detectProvider(account.imap_host);
            
            // Scroll zu Formular
            document.getElementById('accountFormCard').scrollIntoView({ behavior: 'smooth' });
        })
        .catch(error => {
            console.error('Error:', error);
            showImapNotification('Fehler beim Laden', 'error');
        });
}

function cancelForm() {
    document.getElementById('accountFormCard').style.display = 'none';
    document.getElementById('accountForm').reset();
    currentAccountId = null;
}

// Provider auto-detect
function detectProvider(host) {
    for (const [key, provider] of Object.entries(PROVIDERS)) {
        if (provider.host === host) {
            selectProviderByKey(key);
            return;
        }
    }
    selectProviderByKey('custom');
}

function selectProviderByKey(key) {
    const buttons = document.querySelectorAll('.provider-button');
    buttons.forEach((btn, index) => {
        btn.classList.remove('active');
        if (Object.keys(PROVIDERS)[index] === key) {
            btn.classList.add('active');
        }
    });
}

// =============================================================
// Account speichern
// =============================================================

async function saveAccount(event) {
    event.preventDefault();
    
    const formData = {
        email: document.getElementById('email').value,
        username: document.getElementById('username').value || null,
        password: document.getElementById('password').value,
        host: document.getElementById('host').value,
        port: parseInt(document.getElementById('port').value),
        use_ssl: document.getElementById('useSsl').checked,
        csrf_token: getCsrfToken()
    };
    
    // Validierung
    if (!formData.email || !formData.password || !formData.host) {
        showIampNotification('Bitte alle Pflichtfelder ausfüllen', 'error');
        return;
    }
    
    try {
        let url, method;
        
        if (currentAccountId) {
            // Update
            url = `api/imap-accounts/update/${currentAccountId}`;
            method = 'PUT';
        } else {
            // Create
            url = 'api/imap-accounts/save';
            method = 'POST';
        }
        
        const response = await fetch(url, {
            method: method,
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(formData)
        });
        
        const result = await response.json();
        
        if (result.success) {
            showImapNotification('Account erfolgreich gespeichert!', 'success');
            cancelForm();
            loadAccountsList();
        } else {
            showImapNotification('Fehler: ' + result.error, 'error');
        }
        
    } catch (error) {
        console.error('Error:', error);
        showImapNotification('Netzwerkfehler beim Speichern', 'error');
    }
}

// =============================================================
// Account-Liste laden
// =============================================================

async function loadAccountsList() {
    try {
        const response = await fetch('api/imap-accounts/list');
        const accounts = await response.json();
        
        if (accounts.error) {
            showNotification('Fehler: ' + accounts.error, 'error');
            return;
        }
        
        displayAccounts(accounts);
        
    } catch (error) {
        console.error('Error:', error);
        showNotification('Fehler beim Laden der Accounts', 'error');
    }
}

function displayAccounts(accounts) {
    console.log(accounts);
    const container = document.getElementById('accountList');
    
    if (!accounts || accounts.length === 0) {
        container.innerHTML = `
            <div class="empty-state">
                <span class="material-icons">inbox</span>
                <h3>Keine Accounts vorhanden</h3>
                <p>Füge deinen ersten E-Mail-Account hinzu, um zu starten.</p>
            </div>
        `;
        return;
    }
    
    const accountItems = accounts.map(account => {
        const createdDate = new Date(account.created_at);
        const providerName = getProviderName(account.imap_host);
        const providerIcon = getProviderIcon(account.imap_host);
        
        return `
            <div class="account-item" data-account-id="${account.id}">
                <div class="account-item-icon">
                    ${providerIcon}
                </div>
                <div class="account-item-content">
                    <div class="account-item-header">
                        <h3>${escapeHtml(account.email)}</h3>
                        <div class="account-item-badge ${account.use_ssl ? 'badge-success' : 'badge-warning'}">
                            <span class="material-icons">${account.use_ssl ? 'lock' : 'lock_open'}</span>
                            ${account.use_ssl ? 'SSL' : 'Unverschlüsselt'}
                        </div>
                    </div>
                    <p class="account-item-description">
                        <span class="material-icons">dns</span>
                        ${escapeHtml(account.imap_host)}:${account.imap_port}
                        ${providerName ? `<span class="provider-tag">${providerName}</span>` : ''}
                    </p>
                    <div class="account-item-meta">
                        <small>
                            <span class="material-icons">schedule</span>
                            Erstellt: ${createdDate.toLocaleDateString('de-DE')}
                        </small>
                    </div>
                </div>
                <div class="account-item-actions">
                    <button class="icon-btn" onclick="testConnection(${account.id})" title="Verbindung testen">
                        <span class="material-icons">wifi_tethering</span>
                    </button>
                    <button class="icon-btn" onclick="showEditAccountForm(${account.id})" title="Bearbeiten">
                        <span class="material-icons">edit</span>
                    </button>
                    <button class="icon-btn icon-btn--danger" onclick="deleteAccount(${account.id})" title="Löschen">
                        <span class="material-icons">delete</span>
                    </button>
                </div>
            </div>
        `;
    }).join('');
    
    container.innerHTML = accountItems;
}

// Provider-Name ermitteln
function getProviderName(host) {
    for (const [key, provider] of Object.entries(PROVIDERS)) {
        if (provider.host === host) {
            return provider.name;
        }
    }
    return null;
}

// Provider-Icon ermitteln
function getProviderIcon(host) {
    const icons = {
        'imap.gmail.com': '📧',
        'outlook.office365.com': '📨',
        'imap.mail.yahoo.com': '✉️',
        'imap.gmx.net': '📬',
        'imap.web.de': '📭',
        'imap.mail.me.com': '☁️'
    };
    
    return icons[host] || '<span class="material-icons">email</span>';
}

// =============================================================
// Account löschen
// =============================================================

async function deleteAccount(accountId) {
    if (!confirm('Möchtest du diesen Account wirklich löschen?')) {
        return;
    }
    
    try {
        const response = await fetch(`api/imap-accounts/delete/${accountId}`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                csrf_token: getCsrfToken()
            })
        });
        
        const result = await response.json();
        
        if (result.success) {
            showNotification('Account gelöscht', 'success');
            loadAccountsList();
        } else {
            showNotification('Fehler: ' + result.error, 'error');
        }
        
    } catch (error) {
        console.error('Error:', error);
        showNotification('Fehler beim Löschen', 'error');
    }
}

// =============================================================
// Verbindung testen
// =============================================================

async function testConnection(accountId) {
    showNotification('Teste Verbindung...', 'info');
    
    try {
        const response = await fetch(`api/imap-accounts/test/${accountId}`);
        const result = await response.json();
        
        if (result.success) {
            showNotification('✅ Verbindung erfolgreich!', 'success');
        } else {
            showNotification('❌ Verbindung fehlgeschlagen: ' + result.message, 'error');
        }
        
    } catch (error) {
        console.error('Error:', error);
        showNotification('Fehler beim Testen', 'error');
    }
}

async function testAccountConnection() {
    // Test mit aktuellen Formular-Daten (ohne zu speichern)
    const formData = {
        email: document.getElementById('email').value,
        username: document.getElementById('username').value || document.getElementById('email').value,
        password: document.getElementById('password').value,
        host: document.getElementById('host').value,
        port: parseInt(document.getElementById('port').value),
        use_ssl: document.getElementById('useSsl').checked
    };
    
    if (!formData.password || !formData.host) {
        showNotification('Bitte Passwort und Host angeben', 'error');
        return;
    }
    
    showNotification('Teste Verbindung...', 'info');
    
    try {
        const response = await fetch('api/imap-accounts/test-direct', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(formData)
        });
        
        const result = await response.json();
        
        if (result.success) {
            showNotification('✅ Verbindung erfolgreich! Du kannst den Account jetzt speichern.', 'success');
        } else {
            showNotification('❌ Verbindung fehlgeschlagen: ' + result.message, 'error');
        }
        
    } catch (error) {
        console.error('Error:', error);
        showNotification('Fehler beim Testen', 'error');
    }
}

// =============================================================
// Passwort-Sichtbarkeit
// =============================================================

function togglePasswordVisibility() {
    const passwordInput = document.getElementById('password');
    const icon = document.getElementById('passwordIcon');
    
    if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        icon.textContent = 'visibility';
    } else {
        passwordInput.type = 'password';
        icon.textContent = 'visibility_off';
    }
}

// =============================================================
// Hilfsfunktionen
// =============================================================

function getCsrfToken() {
    const meta = document.querySelector('meta[name="csrf_token"]');
    return meta ? meta.content : '';
}

function showImapNotification(message, type = 'info') {
    // Einfache Implementierung - kann durch Toast/Snackbar ersetzt werden
    const banner = document.querySelector('.info-banner');
    const icon = banner.querySelector('.material-icons');
    const text = banner.querySelector('.info-banner-text');
    
    // Icon anpassen
    const icons = {
        'info': 'info',
        'success': 'check_circle',
        'error': 'error',
        'warning': 'warning'
    };
    
    icon.textContent = icons[type] || 'info';
    text.textContent = message;
    
    // Farbe anpassen
    banner.className = 'info-banner info-banner--' + type;
    
    // Nach 5 Sekunden ausblenden
    setTimeout(() => {
        banner.className = 'info-banner';
        icon.textContent = 'info';
        text.textContent = 'Alle Passwörter werden verschlüsselt gespeichert. Für Gmail/Outlook nutze App-Passwörter statt deines normalen Passworts.';
    }, 5000);
}



    </script>
