 <div class="app-bar">
            <div class="app-bar-content">
                <div class="app-bar-left">
                    <button class="back-button" onclick="goBack()" title="Zurück">
                        <span class="material-icons">arrow_back</span>
                    </button>
                    <div>
                        <h1>
                            <span class="material-icons">edit</span>
                            Email Subject Changer
                        </h1>
                        <p>Ändere E-Mail-Betreffe direkt im Postfach</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="container">
            <div class="info-banner">
                <span class="material-icons">info</span>
                <div class="info-banner-text">
                    Konfiguriere die Verbindung zu deinem IMAP-Server und definiere, wie Betreffe geändert werden sollen.
                </div>
            </div>

            <div class="mdc-card">
                <div class="card-header">
                    <span class="material-icons">dns</span>
                    <h2>IMAP Server Konfiguration</h2>
                </div>
                <div class="card-content">
                    <div class="input-grid">
                        <div class="mdc-text-field">
                            <label>Server (Host)</label>
                            <input type="text" id="imapHost" placeholder="imap.gmail.com" value="imap.gmail.com">
                        </div>
                        <div class="mdc-text-field">
                            <label>Port</label>
                            <input type="number" id="imapPort" placeholder="993" value="993">
                        </div>
                        <div class="mdc-text-field">
                            <label>Benutzername</label>
                            <input type="text" id="imapUser" placeholder="user@example.com">
                        </div>
                        <div class="mdc-text-field">
                            <label>Passwort</label>
                            <input type="password" id="imapPass" placeholder="••••••••">
                        </div>
                    </div>
                </div>
            </div>

            <div class="mdc-card">
                <div class="card-header">
                    <span class="material-icons">filter_alt</span>
                    <h2>Suchkriterien (Welche E-Mails?)</h2>
                </div>
                <div class="card-content">
                    <div class="mdc-text-field">
                        <label>IMAP Suchkriterien</label>
                        <input type="text" id="subjectSearchCriteria" placeholder='z.B. "UNSEEN FROM newsletter@example.com"' value="ALL">
                    </div>
                    <p style="font-size: 12px; color: #757575; margin-top: 8px;">
                        Verwende den Search Builder, um Kriterien zu erstellen
                    </p>
                </div>
            </div>

            <div class="mdc-card">
                <div class="card-header">
                    <span class="material-icons">transform</span>
                    <h2>Betreff-Änderung</h2>
                </div>
                <div class="card-content">
                    <div class="checkbox-grid" style="margin-bottom: 20px;">
                        <div class="mdc-form-field">
                            <div class="mdc-checkbox">
                                <input type="radio" name="subjectMode" id="modePrefix" checked onchange="updateSubjectMode()">
                            </div>
                            <label for="modePrefix">Präfix hinzufügen</label>
                        </div>
                        <div class="mdc-form-field">
                            <div class="mdc-checkbox">
                                <input type="radio" name="subjectMode" id="modeReplace" onchange="updateSubjectMode()">
                            </div>
                            <label for="modeReplace">Text ersetzen</label>
                        </div>
                        <div class="mdc-form-field">
                            <div class="mdc-checkbox">
                                <input type="radio" name="subjectMode" id="modeCustom" onchange="updateSubjectMode()">
                            </div>
                            <label for="modeCustom">Eigene Funktion</label>
                        </div>
                    </div>

                    <div id="prefixMode">
                        <div class="mdc-text-field">
                            <label>Präfix</label>
                            <input type="text" id="subjectPrefix" placeholder='z.B. "[BEARBEITET] "'>
                        </div>
                    </div>

                    <div id="replaceMode" style="display: none;">
                        <div class="input-grid">
                            <div class="mdc-text-field">
                                <label>Suchen nach</label>
                                <input type="text" id="subjectSearch" placeholder="z.B. Newsletter">
                            </div>
                            <div class="mdc-text-field">
                                <label>Ersetzen durch</label>
                                <input type="text" id="subjectReplace" placeholder="z.B. Info">
                            </div>
                        </div>
                    </div>

                    <div id="customMode" style="display: none;">
                        <div class="mdc-text-field">
                            <label>PHP Callback-Funktion</label>
                            <textarea id="subjectCustom" placeholder="function($oldSubject, $header) {&#10;    return strtoupper($oldSubject);&#10;}"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mdc-card">
                <div class="card-header">
                    <span class="material-icons">code</span>
                    <h2>Generierter PHP-Code</h2>
                </div>
                <div class="card-content">
                    <div class="code-block">
                        <button class="copy-button" onclick="copySubjectCode()">
                            <span class="material-icons">content_copy</span>
                            Kopieren
                        </button>
                        <pre id="subjectCodeOutput" style="margin: 0; white-space: pre-wrap;"><code><span class="code-variable">$changer</span> = <span class="code-keyword">new</span> <span class="code-function">EmailSubjectChanger</span>(
    host: <span class="code-string">'<span id="hostOutput">imap.gmail.com</span>'</span>,
    port: <span id="portOutput">993</span>,
    username: <span class="code-string">'<span id="userOutput">user@example.com</span>'</span>,
    password: <span class="code-string">'<span id="passOutput">password</span>'</span>
);

<span class="code-variable">$count</span> = <span class="code-variable">$changer</span>-><span class="code-function">changeSubjects</span>(<span class="code-string">'<span id="criteriaOutput">ALL</span>'</span>, <span class="code-keyword">function</span>(<span class="code-variable">$oldSubject</span>) {
    <span class="code-keyword">return</span> <span class="code-string">"[BEARBEITET] "</span> . <span class="code-variable">$oldSubject</span>;
});</code></pre>
                    </div>
                </div>
            </div>
        </div>

        <div class="fab-container">
            <button class="mdc-fab" onclick="scrollToTop('subjectSection')" title="Nach oben">
                <span class="material-icons">arrow_upward</span>
            </button>
        </div>